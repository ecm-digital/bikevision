rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public forms — anyone can create, nobody can read/update/delete from client
    match /leads/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /beta_testers/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /newsletter_subscribers/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /orders/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /counters/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Admin panel — authenticated users can read all collections
    match /{collection}/{docId} {
      allow read: if request.auth != null;
    }
  }
}
